# Copie ce fichier : cp .env.example .env  puis nano .env
# Ne commite JAMAIS .env (secrets). PROCESS_ROLE ne va pas dans .env si tu utilises PM2 ecosystem.config.cjs (alps-web / alps-bot).

# --- Obligatoire ---
BOT_TOKEN=REMPLACER_TOKEN_BOTFATHER
OWNER_CHAT_ID=REMPLACER_TON_CHAT_ID_TELEGRAM

# --- Site catalogue (HTTPS, sans / final) ---
CATALOG_URL=https://alpine710.art

# --- Ports & TLS (Node direct sur 443) ---
PORT=443
HTTP_REDIRECT_PORT=80
NODE_SSL_CERT=/etc/letsencrypt/live/alpine710.art/fullchain.pem
NODE_SSL_KEY=/etc/letsencrypt/live/alpine710.art/privkey.pem
# LISTEN_HOST=0.0.0.0

# --- Mini App Telegram ---
TELEGRAM_WEBAPP_ONLY=1
# TELEGRAM_HTML_NO_BLOCK=1
# TELEGRAM_HTML_UA_ONLY=1

# --- Liens contact (catalogue) ---
# SIGNAL_CONTACT_URL=https://signal.me/...
# THREEMA_CONTACT_URL=https://threema.id/...

# --- Médias catalogue (optionnel) ---
# PROXY_MEDIA_URLS=1
# MEDIA_ALLOWED_HOSTS=res.cloudinary.com

# --- Bot : accueil & commandes ---
# WELCOME_IMAGE_URL=https://...
# WELCOME_PROMO_LINE=🎁 Ton message promo court ici
# ORDER_RESPONSE_SLA_HOURS=12
# THANK_YOU_LINE_FR=Merci pour ta confiance — à très vite.
# THANK_YOU_LINE_EN=Thanks — we’ll be in touch soon.
# THANK_YOU_LINE_DE=Vielen Dank — wir melden uns bald.

# --- Rappels panier (désactivé par défaut : laisse commenté ou =0) ---
# CART_REMINDER_ENABLED=1
# CART_REMINDER_AFTER_MINUTES=15
# CART_REMINDER_REPEAT_HOURS=24
# CART_REMINDER_CHECK_EVERY_SECONDS=120
